# TypeScript 开发规范

## 基础配置

始终开启严格模式，推荐 `tsconfig.json` 配置：

```json
{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
```

## 类型定义规范

### interface vs type

- 使用 `interface` 定义对象结构（可扩展、有更好的错误提示）
- 使用 `type` 定义联合类型、交叉类型、工具类型、元组

```typescript
// 推荐：使用 interface 定义对象
interface User {
  id: string
  name: string
  email: string
}

// 推荐：扩展接口
interface AdminUser extends User {
  permissions: string[]
}

// 推荐：使用 type 定义联合类型
type Status = 'active' | 'inactive' | 'pending'
type ID = string | number

// 推荐：工具类型
type PartialUser = Partial<User>
type CreateUserInput = Omit<User, 'id'>
```

### 命名规范

- 接口/类型名使用 PascalCase：`UserProfile`、`ApiResponse<T>`
- 泛型参数使用单个大写字母或描述性名称：`T`、`TData`、`TError`
- 不在接口名前加 `I` 前缀（避免 `IUser`，使用 `User`）
- 枚举值使用 PascalCase

```typescript
// 推荐
enum Direction {
  Up = 'UP',
  Down = 'DOWN',
  Left = 'LEFT',
  Right = 'RIGHT',
}

// 泛型命名
interface ApiResponse<TData> {
  data: TData
  code: number
  message: string
}

async function fetchData<TData>(url: string): Promise<ApiResponse<TData>> {
  // ...
}
```

## 函数类型注解

- 为函数参数和返回值显式添加类型
- 使用函数重载处理复杂的多态场景

```typescript
// 推荐：显式类型注解
function formatDate(date: Date, format: string): string {
  // ...
}

// 箭头函数
const add = (a: number, b: number): number => a + b

// 函数重载
function parse(input: string): number
function parse(input: string[]): number[]
function parse(input: string | string[]): number | number[] {
  if (Array.isArray(input)) {
    return input.map(Number)
  }
  return Number(input)
}
```

## 类型断言与类型守卫

- 优先使用类型守卫而非类型断言（`as`）
- 避免使用 `any`，使用 `unknown` 替代
- 使用 `satisfies` 操作符验证类型同时保留字面量类型

```typescript
// 推荐：类型守卫
function isUser(value: unknown): value is User {
  return (
    typeof value === 'object' &&
    value !== null &&
    'id' in value &&
    'name' in value
  )
}

// 推荐：unknown 代替 any
async function fetchJson(url: string): Promise<unknown> {
  const response = await fetch(url)
  return response.json()
}

const data = await fetchJson('/api/user')
if (isUser(data)) {
  console.log(data.name) // 安全访问
}

// 推荐：satisfies 操作符
const config = {
  host: 'localhost',
  port: 3000,
} satisfies ServerConfig
```

## 泛型最佳实践

```typescript
// 约束泛型参数
function getProperty<T, K extends keyof T>(obj: T, key: K): T[K] {
  return obj[key]
}

// 条件类型
type NonNullable<T> = T extends null | undefined ? never : T

// 映射类型
type ReadOnly<T> = {
  readonly [K in keyof T]: T[K]
}

// 模板字面量类型
type EventName<T extends string> = `on${Capitalize<T>}`
type ClickEvent = EventName<'click'> // 'onClick'
```

## 模块化规范

- 使用 ES Module（`import`/`export`）
- 使用命名导出而非默认导出（便于重构和 IDE 提示）
- 类型和值分开导入

```typescript
// 推荐：命名导出
export interface User { ... }
export function createUser(input: CreateUserInput): User { ... }
export const DEFAULT_USER: User = { ... }

// 推荐：类型导入
import type { User, CreateUserInput } from './types'
import { createUser } from './user-service'
```

## 错误处理

```typescript
// 自定义错误类
class AppError extends Error {
  constructor(
    message: string,
    public readonly code: string,
    public readonly statusCode: number = 500,
  ) {
    super(message)
    this.name = 'AppError'
  }
}

// Result 类型模式（避免 try-catch 地狱）
type Result<T, E = Error> =
  | { success: true; data: T }
  | { success: false; error: E }

async function safeOperation<T>(
  fn: () => Promise<T>,
): Promise<Result<T>> {
  try {
    const data = await fn()
    return { success: true, data }
  } catch (error) {
    return {
      success: false,
      error: error instanceof Error ? error : new Error(String(error)),
    }
  }
}
```

## 避免的反模式

```typescript
// ❌ 避免 any
function process(data: any) { ... }

// ✅ 使用 unknown + 类型守卫
function process(data: unknown) {
  if (isExpectedType(data)) { ... }
}

// ❌ 避免非空断言（!）
const user = getUser()!.name

// ✅ 使用可选链和空值合并
const user = getUser()?.name ?? 'Anonymous'

// ❌ 避免类型断言绕过检查
const result = response as unknown as User

// ✅ 使用类型守卫
if (isUser(response)) {
  const result = response
}
```
